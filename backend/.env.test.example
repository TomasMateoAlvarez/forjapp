# Copiá a .env.test (gitignored) para correr `npm test` localmente. Apunta al
# mismo Postgres de desarrollo — cada archivo de test crea y destruye su
# propia base (test_<pid>_<random>) dentro de este servidor, no toca `forja`.
# El usuario de esta connection string necesita permiso para CREATE/DROP DATABASE.
DATABASE_URL=postgresql://forja:forja@localhost:5432/forja
