# Puerto donde escucha la API. Render lo inyecta solo — no hace falta
# definirlo en producción. Si no se define localmente, usa 4000.
PORT=4000

# Connection string de Postgres (node-postgres / `pg`). Requerida siempre —
# no hay fallback ni base embebida. Para desarrollo local, la forma más simple
# es Postgres en Docker:
#   docker run -d --name forja-postgres -e POSTGRES_USER=forja -e POSTGRES_PASSWORD=forja -e POSTGRES_DB=forja -p 5432:5432 postgres:16-alpine
# En producción (Render) apunta a la connection string de Neon — nunca la
# hardcodees ni la commitees.
DATABASE_URL=postgresql://forja:forja@localhost:5432/forja

# Dominio del frontend en producción (Vercel), para restringir CORS. Sin esta
# variable, CORS queda abierto (desarrollo local / instalaciones en LAN).
# FRONTEND_ORIGIN=https://tu-app.vercel.app
